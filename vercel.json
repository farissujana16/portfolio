{
  "builds": [
    { "src": "/api/index.php", "use": "vercel-php@0.7.1" },
    { "src": "/api/assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/(css|js|vendor|assets|build)/(.*)",
      "dest": "/api/assets/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
