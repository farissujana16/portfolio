{
  "builds": [{ "src": "/api/index.php", "use": "vercel-php@0.7.1" }],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    },
    {
      "src": "/assets/image/(.*)",
      "dest": "/api/assets/$1/$2"
    },
    {
      "src": "/assets/cv.pdf",
      "dest": "/api/assets/cv.pdf"
    }
  ]
}
